# Convex
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=
PUBLIC_CONVEX_HTTP_ACTIONS_URL=
CONVEX_SITE_URL=

# Auth mode
AUTH_MODE=laventecare
PUBLIC_AUTH_MODE=laventecare

# LaventeCare AuthSystem
LAVENTECARE_API_URL=https://laventecareauthsystems.onrender.com/api/v1
LAVENTECARE_TENANT_ID=

# Henke Wonen keeps its existing Convex/data tenant slug separate from the
# LaventeCare tenant slug. Do not change this to the backend slug unless the
# Convex data has also been migrated.
HENKE_TENANT_SLUG=henke-wonen
AUTH_TENANT_NAME=Henke Wonen

# Must be identical in Astro/Vercel and Convex environment variables.
AUTHZ_TOKEN_SECRET=
