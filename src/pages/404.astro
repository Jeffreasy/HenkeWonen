---
// Eigen 404-pagina — zonder deze pagina toont Astro/hosting een kale foutpagina.
// Bewust zelfstandig (geen layout/session): moet ook renderen als er niets anders werkt.
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Pagina niet gevonden | Henke Wonen</title>
  </head>
  <body class="ep-body">
    <main class="ep-card">
      <p class="ep-code" aria-hidden="true">404</p>
      <p class="ep-eyebrow">Henke Wonen werkplek</p>
      <h1 class="ep-title">Deze pagina bestaat niet</h1>
      <p class="ep-desc">
        De pagina is verplaatst of het adres klopt niet meer. Ga terug naar de
        werkplek of naar de startpagina.
      </p>
      <div class="ep-actions">
        <a class="ep-btn ep-btn--primary" href="/portal">Naar de werkplek</a>
        <a class="ep-btn ep-btn--ghost" href="/">Naar de startpagina</a>
      </div>
    </main>
  </body>
</html>

<style>
  .ep-body {
    margin: 0;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0d0b09;
    color: #f7f2ea;
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    text-align: center;
    padding: 24px;
  }

  .ep-card {
    max-width: 440px;
    display: grid;
    gap: 14px;
    justify-items: center;
  }

  .ep-code {
    margin: 0;
    font-size: 3.4rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: rgba(184, 137, 58, 0.4);
    line-height: 1;
  }

  .ep-eyebrow {
    margin: 0;
    color: #b8893a;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ep-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .ep-desc {
    margin: 0;
    color: rgba(247, 242, 234, 0.65);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .ep-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    padding-top: 8px;
  }

  .ep-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 750;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .ep-btn--primary {
    background: linear-gradient(135deg, #c4953f 0%, #9c7228 100%);
    color: #fff;
    box-shadow: 0 4px 16px rgba(155, 100, 25, 0.36);
  }

  .ep-btn--primary:hover,
  .ep-btn--primary:focus-visible {
    transform: translateY(-1px);
    outline: 2px solid #b8893a;
    outline-offset: 2px;
  }

  .ep-btn--ghost {
    color: rgba(247, 242, 234, 0.75);
    border: 1px solid rgba(184, 137, 58, 0.3);
  }

  .ep-btn--ghost:hover,
  .ep-btn--ghost:focus-visible {
    color: #f7f2ea;
    outline: 2px solid #b8893a;
    outline-offset: 2px;
  }
</style>
