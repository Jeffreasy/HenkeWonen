---
import "../styles/global.css";

const authMode = import.meta.env.AUTH_MODE ?? import.meta.env.PUBLIC_AUTH_MODE ?? "laventecare";
const loginUrl = import.meta.env.LAVENTECARE_LOGIN_URL;
const isDevAuth = authMode === "dev";
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login | Henke Wonen</title>
  </head>
  <body>
    <main class="portal-main" style="margin-left: 0">
      <section class="panel" style="max-width: 520px">
        <p class="eyebrow">Henke Wonen</p>
        <h1 class="section-title">Login</h1>
        {
          isDevAuth ? (
            <>
              <p class="muted">
                Lokale ontwikkelsessie actief. Deze automatische toegang is alleen bedoeld voor
                ontwikkelwerk en staat buiten de ontwikkelomgeving uit.
              </p>
              <a class="button primary" href="/portal">Naar werkplek</a>
            </>
          ) : (
            <>
              <p class="muted">
                Log in via LaventeCare om toegang te krijgen tot de Henke Wonen werkplek.
              </p>
              {loginUrl ? (
                <a class="button primary" href={loginUrl}>Inloggen via LaventeCare</a>
              ) : (
                <p class="empty-state">Inloggen is nog niet gekoppeld. Neem contact op met de beheerder.</p>
              )}
            </>
          )
        }
      </section>
    </main>
  </body>
</html>
