---
import "../styles/global.css";
import { resolveAuthMode } from "../lib/auth/mode";
import {
  hasLaventeCareApiConnection,
  laventeCareLoginUrl
} from "../lib/auth/laventeCareConfig";

const authMode = resolveAuthMode();
const loginUrl = laventeCareLoginUrl();
const isDevAuth = authMode === "dev";
const hasLaventeCareApi = hasLaventeCareApiConnection();
const hasLaventeCareConnection = hasLaventeCareApi || Boolean(loginUrl);
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Toegang | Henke Wonen</title>
  </head>
  <body>
    <main class="login-shell">
      <section class="login-frame" aria-labelledby="login-title">
        <div class="login-brand-panel">
          <a class="login-logo" href="/" aria-label="Henke Wonen">
            <span>HW</span>
            <strong>Henke Wonen</strong>
          </a>
          <div class="login-brand-copy">
            <p class="eyebrow">Beveiligde werkplek</p>
            <h1 id="login-title">Toegang tot de Henke Wonen portal</h1>
            <p>
              Een centrale omgeving voor dossiers, offertes, klantbezoeken en de dagelijkse
              winkelwerkzaamheden.
            </p>
          </div>
          <div class="login-status-list" aria-label="Status van de omgeving">
            <span class="login-status-pill success">Applicatie online</span>
            <span class={`login-status-pill ${isDevAuth || hasLaventeCareConnection ? "success" : "warning"}`}>
              {isDevAuth ? "Ontwikkeltoegang actief" : hasLaventeCareConnection ? "LaventeCare gekoppeld" : "LaventeCare wacht op koppeling"}
            </span>
          </div>
        </div>

        <div class="login-action-panel">
          <p class="eyebrow">Inloggen</p>
          <h2>{isDevAuth ? "Ontwikkelomgeving" : "Welkom bij Henke Wonen"}</h2>
        {
          isDevAuth ? (
            <>
              <p class="login-intro">
                Je gebruikt een lokale ontwikkelsessie. Deze toegang is alleen bedoeld voor
                ontwikkelwerk en staat in productie uit.
              </p>
              <a class="button primary" href="/portal">Naar werkplek</a>
            </>
          ) : hasLaventeCareApi ? (
            <>
              <p class="login-intro">
                Log veilig in met je LaventeCare-account. Je sessie blijft beveiligd in de Henke
                Wonen omgeving.
              </p>
              <form class="login-form" data-login-form>
                <label class="login-field" for="email">
                  <span>E-mailadres</span>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="username"
                    required
                    placeholder="naam@bedrijf.nl"
                  />
                </label>
                <label class="login-field" for="password">
                  <span>Wachtwoord</span>
                  <input
                    id="password"
                    name="password"
                    type="password"
                    autocomplete="current-password"
                    required
                  />
                </label>
                <p class="login-form-message" data-login-message hidden></p>
                <button class="button primary login-action-button" type="submit">
                  Inloggen
                </button>
              </form>
              <p class="login-footnote">
                De login loopt via LaventeCare AuthSystem. Daarna wordt je Henke Wonen werkplek
                automatisch voorbereid.
              </p>
            </>
          ) : hasLaventeCareConnection && loginUrl ? (
            <>
              <p class="login-intro">
                Log veilig in via LaventeCare om toegang te krijgen tot de Henke Wonen werkplek.
              </p>
              <a class="button primary login-action-button" href={loginUrl}>Inloggen via LaventeCare</a>
              <p class="login-footnote">
                Je wordt doorgestuurd naar LaventeCare. Na het inloggen kom je automatisch terug in
                de portal.
              </p>
            </>
          ) : (
            <>
              <p class="login-intro">
                De portal staat klaar. De laatste stap is het koppelen van de LaventeCare-login.
              </p>
              <div class="login-notice" role="status">
                <strong>Login nog niet geactiveerd</strong>
                <p>
                  Zodra LaventeCare is gekoppeld, kunnen medewerkers hier veilig inloggen met hun
                  bestaande account.
                </p>
              </div>
              <div class="login-next-steps" aria-label="Volgende stappen">
                <div>
                  <span>1</span>
                  <p>LaventeCare-koppeling activeren</p>
                </div>
                <div>
                  <span>2</span>
                  <p>Medewerkerrechten controleren</p>
                </div>
                <div>
                  <span>3</span>
                  <p>Portal vrijgeven voor dagelijks gebruik</p>
                </div>
              </div>
              <span class="login-disabled-action" aria-disabled="true">
                Inloggen beschikbaar na koppeling
              </span>
            </>
          )
        }
        </div>
      </section>
    </main>
  </body>
</html>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-login-form]");
  const message = document.querySelector<HTMLElement>("[data-login-message]");

  function showLoginMessage(text: string, kind: "error" | "info" = "error") {
    if (!message) {
      return;
    }

    message.hidden = false;
    message.textContent = text;
    message.dataset.kind = kind;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const formData = new FormData(form);
    const email = String(formData.get("email") ?? "");
    const password = String(formData.get("password") ?? "");

    if (message) {
      message.hidden = true;
      message.textContent = "";
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = "Inloggen...";
    }

    try {
      const response = await fetch("/api/auth/login", {
        method: "POST",
        headers: {
          "content-type": "application/json"
        },
        credentials: "include",
        body: JSON.stringify({ email, password })
      });
      const payload = (await response.json().catch(() => ({}))) as {
        error?: string;
        message?: string;
        mfa_required?: boolean;
      };

      if (!response.ok) {
        throw new Error(payload.error ?? payload.message ?? "Inloggen is niet gelukt.");
      }

      if (payload.mfa_required) {
        showLoginMessage(
          "Deze account vraagt om extra verificatie. Rond MFA af via LaventeCare of vraag beheer om hulp.",
          "info"
        );
        return;
      }

      window.location.assign("/portal");
    } catch (error) {
      showLoginMessage(
        error instanceof Error
          ? error.message
          : "Inloggen is niet gelukt. Controleer je gegevens en probeer opnieuw."
      );
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = "Inloggen";
      }
    }
  });
</script>

<style>
  .login-shell {
    display: grid;
    width: 100%;
    max-width: 100vw;
    min-height: 100vh;
    overflow-x: hidden;
    place-items: center;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.86), rgba(244, 246, 242, 0.92)),
      var(--bg);
    padding: clamp(18px, 4vw, 48px);
  }

  .login-frame {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.75fr);
    width: min(100%, 1040px);
    max-width: 100%;
    min-height: 560px;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-raised);
    box-shadow: var(--shadow-md);
  }

  .login-brand-panel,
  .login-action-panel {
    display: grid;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    padding: clamp(24px, 4vw, 44px);
  }

  .login-brand-panel {
    align-content: space-between;
    gap: var(--space-8);
    background: #171511;
    color: #fbf7ef;
  }

  .login-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    width: fit-content;
    font-weight: 900;
  }

  .login-logo span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.08);
    color: #f4e6cf;
    font-size: var(--text-sm);
  }

  .login-logo strong {
    color: #fff;
    font-size: var(--text-lg);
  }

  .login-brand-copy {
    display: grid;
    gap: var(--space-3);
    min-width: 0;
    max-width: min(100%, 620px);
  }

  .login-brand-copy .eyebrow,
  .login-action-panel .eyebrow {
    color: #c98b3a;
  }

  .login-brand-copy h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: var(--line-tight);
    letter-spacing: 0;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .login-brand-copy p:not(.eyebrow) {
    max-width: 58ch;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--text-lg);
    line-height: var(--line-normal);
    overflow-wrap: anywhere;
  }

  .login-status-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .login-status-pill {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    min-width: 0;
    min-height: 30px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    padding: 0 var(--space-3);
    font-size: var(--text-xs);
    font-weight: 900;
    overflow-wrap: anywhere;
    text-align: center;
    white-space: normal;
  }

  .login-status-pill.success {
    background: rgba(22, 101, 52, 0.28);
    color: #dcfce7;
  }

  .login-status-pill.warning {
    background: rgba(154, 101, 7, 0.28);
    color: #fef3c7;
  }

  .login-action-panel {
    align-content: center;
    gap: var(--space-4);
    background: var(--surface);
  }

  .login-action-panel h2 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    line-height: var(--line-tight);
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .login-intro,
  .login-footnote,
  .login-notice p,
  .login-next-steps p {
    margin: 0;
    color: var(--muted);
    line-height: var(--line-normal);
    overflow-wrap: anywhere;
  }

  .login-action-button {
    width: fit-content;
    min-height: 46px;
    padding-inline: var(--space-5);
  }

  .login-form {
    display: grid;
    gap: var(--space-3);
    width: min(100%, 380px);
    max-width: 100%;
  }

  .login-field {
    display: grid;
    gap: var(--space-2);
    color: var(--ink);
    font-size: var(--text-sm);
    font-weight: 850;
  }

  .login-field input {
    min-height: 44px;
    width: 100%;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    background: var(--surface-raised);
    color: var(--ink);
    font: inherit;
    font-weight: 650;
    padding: 0 var(--space-3);
  }

  .login-field input:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(185, 120, 43, 0.18);
    outline: none;
  }

  .login-form-message {
    margin: 0;
    border: 1px solid rgba(153, 27, 27, 0.18);
    border-radius: var(--radius-md);
    background: var(--danger-bg);
    color: var(--danger);
    padding: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 750;
    line-height: var(--line-normal);
  }

  .login-form-message[data-kind="info"] {
    border-color: rgba(154, 101, 7, 0.24);
    background: var(--warning-bg);
    color: #7c4a03;
  }

  .login-notice {
    display: grid;
    gap: var(--space-2);
    max-width: 100%;
    min-width: 0;
    border: 1px solid rgba(154, 101, 7, 0.24);
    border-left: 5px solid var(--warning);
    border-radius: var(--radius-md);
    background: var(--warning-bg);
    padding: var(--space-4);
  }

  .login-notice strong {
    color: #7c4a03;
  }

  .login-next-steps {
    display: grid;
    gap: var(--space-3);
    max-width: 100%;
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: var(--space-4);
  }

  .login-next-steps div {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-3);
    align-items: center;
  }

  .login-next-steps span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-size: var(--text-sm);
    font-weight: 900;
  }

  .login-disabled-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 42px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-muted);
    color: var(--muted);
    padding: 0 var(--space-4);
    font-weight: 800;
  }

  @media (max-width: 860px) {
    .login-frame {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .login-brand-panel {
      gap: var(--space-8);
    }
  }

  @media (max-width: 560px) {
    .login-shell {
      align-items: stretch;
      display: block;
      overflow-x: hidden;
      padding: var(--space-3);
    }

    .login-frame {
      width: 100%;
      max-width: calc(100vw - 24px);
      margin: 0 auto;
    }

    .login-brand-panel,
    .login-action-panel {
      padding: var(--space-4);
    }

    .login-brand-copy h1 {
      font-size: clamp(1.75rem, 8vw, 2.05rem);
    }

    .login-brand-copy p:not(.eyebrow) {
      font-size: var(--text-md);
    }

    .login-status-list {
      display: grid;
      grid-template-columns: 1fr;
    }

    .login-status-pill {
      justify-content: center;
      width: 100%;
    }

    .login-action-button,
    .login-disabled-action {
      width: 100%;
    }

    .login-form {
      width: 100%;
    }
  }
</style>
