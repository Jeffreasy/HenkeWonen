---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ImportProfiles from "../../../components/imports/ImportProfiles";
import ProductionReadiness from "../../../components/imports/ProductionReadiness";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Btw controle" session={session}>
  <PageHeader
    eyebrow="Beheer"
    title="Btw-keuzes per prijslijst"
    description="Leg per prijskolom vast of bedragen inclusief of exclusief btw zijn, zodat prijslijsten veilig verwerkt kunnen worden."
  />
  <ProductionReadiness client:load session={session} />
  <ImportProfiles client:load session={session} />
</PortalLayout>
