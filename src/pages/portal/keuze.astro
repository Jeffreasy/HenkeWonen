---
import "../../styles/global.css";
import type { AppSession } from "../../lib/auth/session";

const session = Astro.locals.session as AppSession | undefined;

if (!session) {
  return Astro.redirect("/login");
}

const firstName = session.name?.split(" ")[0] ?? "Welkom";
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Werkplek kiezen | Henke Wonen</title>
  </head>
  <body class="wp-body">

    <!-- Ambient glow layers -->
    <div class="wp-bg" aria-hidden="true">
      <div class="wp-glow wp-glow--1"></div>
      <div class="wp-glow wp-glow--2"></div>
    </div>

    <div class="wp-shell">

      <!-- Header -->
      <header class="wp-header">
        <a href="/" aria-label="Henke Wonen — home" class="wp-logo-wrap">
          <img
            src="/images/logo-henke-wonen.png"
            alt="Henke Wonen"
            class="wp-logo"
            width="160"
            height="50"
          />
        </a>

        <div class="wp-welcome">
          <p class="wp-welcome-eyebrow">Ingelogd als</p>
          <p class="wp-welcome-name">{session.name ?? session.email}</p>
        </div>
      </header>

      <!-- Main content -->
      <main class="wp-main" id="wp-main">

        <div class="wp-intro">
          <h1 class="wp-title">Goedemorgen, {firstName}</h1>
          <p class="wp-subtitle">Kies je werkplek voor vandaag</p>
        </div>

        <!-- Workspace cards -->
        <div class="wp-cards" role="list" aria-label="Werkplekken">

          <!-- Winkel -->
          <a
            href="/portal"
            class="wp-card wp-card--winkel"
            role="listitem"
            id="keuze-winkel"
            aria-describedby="desc-winkel"
          >
            <div class="wp-card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>

            <div class="wp-card-content">
              <div class="wp-card-badge">Winkel</div>
              <h2 class="wp-card-title">Winkel &amp; kantoor</h2>
              <p class="wp-card-desc" id="desc-winkel">
                Offertes, dossiers, klanten, catalogus en leveranciers — alles voor de dagelijkse winkelwerkzaamheden.
              </p>
              <ul class="wp-card-tags" aria-label="Beschikbare modules">
                <li>Offertes</li>
                <li>Dossiers</li>
                <li>Catalogus</li>
                <li>Klanten</li>
              </ul>
            </div>

            <div class="wp-card-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>

          <!-- Buitendienst -->
          <a
            href="/portal/buitendienst/vandaag"
            class="wp-card wp-card--buiten"
            role="listitem"
            id="keuze-buitendienst"
            aria-describedby="desc-buiten"
          >
            <div class="wp-card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 20h20"/>
                <path d="m4 20 2-14h12l2 14"/>
                <path d="M12 6V4"/>
                <path d="M6 10h12"/>
                <path d="M8 14h8"/>
              </svg>
            </div>

            <div class="wp-card-content">
              <div class="wp-card-badge wp-card-badge--buiten">Buitendienst</div>
              <h2 class="wp-card-title">Buitendienst</h2>
              <p class="wp-card-desc" id="desc-buiten">
                Opmeetbezoeken plannen en afhandelen, projectnotities en klantbezoeken beheren — onderweg.
              </p>
              <ul class="wp-card-tags" aria-label="Beschikbare modules">
                <li>Opmeten</li>
                <li>Planning</li>
                <li>Projecten</li>
                <li>Notities</li>
              </ul>
            </div>

            <div class="wp-card-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>

        </div>

        <!-- Footer tip -->
        <p class="wp-tip" aria-label="Tip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Je kunt altijd wisselen via de navigatie in het portal.
        </p>

      </main>

      <!-- Footer -->
      <footer class="wp-footer">
        <p>&copy; {new Date().getFullYear()} Henke Wonen</p>
        <a href="/api/auth/logout" class="wp-logout">Uitloggen</a>
      </footer>

    </div>
  </body>
</html>

<style>
  /* ──────────────────────────────────────────────
     TOKENS
  ────────────────────────────────────────────── */
  :root {
    --wp-gold:       #b8893a;
    --wp-gold-dim:   rgba(184, 137, 58, 0.15);
    --wp-gold-glow:  rgba(184, 137, 58, 0.25);
    --wp-dark:       #0d0b09;
    --wp-dark-2:     #1a1510;
    --wp-warm:       #f7f2ea;
    --wp-muted:      rgba(247, 242, 234, 0.52);
    --wp-border:     rgba(255, 255, 255, 0.08);
    --wp-radius:     20px;
    --wp-radius-sm:  12px;
    --wp-buiten:     #1d7a5f;
    --wp-buiten-dim: rgba(29, 122, 95, 0.15);
    --wp-buiten-glow:rgba(29, 122, 95, 0.3);
  }

  *, *::before, *::after { box-sizing: border-box; }

  .wp-body {
    margin: 0;
    padding: 0;
    min-height: 100svh;
    background: var(--wp-dark);
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    color: var(--wp-warm);
    overflow-x: hidden;
  }

  /* ──────────────────────────────────────────────
     BACKGROUND
  ────────────────────────────────────────────── */
  .wp-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .wp-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.22;
    animation: wp-drift 20s ease-in-out infinite alternate;
  }

  .wp-glow--1 {
    width: 700px;
    height: 700px;
    top: -200px;
    left: -150px;
    background: radial-gradient(circle, #b8893a 0%, transparent 70%);
  }

  .wp-glow--2 {
    width: 500px;
    height: 500px;
    bottom: -100px;
    right: -100px;
    background: radial-gradient(circle, #1d7a5f 0%, transparent 70%);
    animation-direction: alternate-reverse;
    animation-duration: 26s;
  }

  @keyframes wp-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(24px, 16px) scale(1.06); }
  }

  /* ──────────────────────────────────────────────
     SHELL
  ────────────────────────────────────────────── */
  .wp-shell {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    padding: clamp(20px, 4vw, 40px) clamp(16px, 5vw, 48px);
    gap: clamp(32px, 5vh, 56px);
  }

  /* ──────────────────────────────────────────────
     HEADER
  ────────────────────────────────────────────── */
  .wp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    animation: wp-fade-down 0.5s ease both;
  }

  .wp-logo-wrap {
    display: inline-block;
    background: #fff;
    border-radius: var(--wp-radius-sm);
    padding: 9px 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    flex-shrink: 0;
  }

  .wp-logo-wrap:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.38);
  }

  .wp-logo {
    display: block;
    height: 38px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
  }

  .wp-welcome {
    text-align: right;
  }

  .wp-welcome-eyebrow {
    margin: 0;
    color: var(--wp-muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .wp-welcome-name {
    margin: 2px 0 0;
    color: var(--wp-warm);
    font-size: 0.9rem;
    font-weight: 650;
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ──────────────────────────────────────────────
     MAIN
  ────────────────────────────────────────────── */
  .wp-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(28px, 4vh, 48px);
  }

  /* ──────────────────────────────────────────────
     INTRO
  ────────────────────────────────────────────── */
  .wp-intro {
    text-align: center;
    animation: wp-fade-up 0.55s 0.05s ease both;
  }

  .wp-title {
    margin: 0 0 10px;
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--wp-warm);
  }

  .wp-subtitle {
    margin: 0;
    color: var(--wp-muted);
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    font-weight: 500;
  }

  /* ──────────────────────────────────────────────
     CARDS
  ────────────────────────────────────────────── */
  .wp-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(14px, 2.5vw, 24px);
    width: 100%;
    max-width: 860px;
    animation: wp-fade-up 0.55s 0.12s ease both;
  }

  .wp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: clamp(24px, 3.5vw, 40px);
    border-radius: var(--wp-radius);
    border: 1px solid var(--wp-border);
    background:
      linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: var(--wp-warm);
    cursor: pointer;
    transition:
      transform 0.25s cubic-bezier(0.34,1.56,0.64,1),
      border-color 0.2s ease,
      box-shadow 0.25s ease;
    overflow: hidden;
  }

  .wp-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  /* Gold card (Winkel) */
  .wp-card--winkel::before {
    background: radial-gradient(circle at 30% 30%, var(--wp-gold-glow) 0%, transparent 60%);
  }

  .wp-card--winkel:hover,
  .wp-card--winkel:focus-visible {
    border-color: rgba(184, 137, 58, 0.4);
    box-shadow: 0 20px 60px rgba(184, 137, 58, 0.18), 0 4px 16px rgba(0,0,0,0.32);
    transform: translateY(-4px) scale(1.005);
  }

  .wp-card--winkel:hover::before,
  .wp-card--winkel:focus-visible::before {
    opacity: 1;
  }

  /* Green card (Buitendienst) */
  .wp-card--buiten::before {
    background: radial-gradient(circle at 30% 30%, var(--wp-buiten-glow) 0%, transparent 60%);
  }

  .wp-card--buiten:hover,
  .wp-card--buiten:focus-visible {
    border-color: rgba(29, 122, 95, 0.4);
    box-shadow: 0 20px 60px rgba(29, 122, 95, 0.2), 0 4px 16px rgba(0,0,0,0.32);
    transform: translateY(-4px) scale(1.005);
  }

  .wp-card--buiten:hover::before,
  .wp-card--buiten:focus-visible::before {
    opacity: 1;
  }

  .wp-card:focus-visible {
    outline: 2px solid var(--wp-gold);
    outline-offset: 3px;
  }

  .wp-card:active {
    transform: translateY(-1px) scale(1);
  }

  /* Icon */
  .wp-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 16px;
    flex-shrink: 0;
  }

  .wp-card--winkel .wp-card-icon {
    background: var(--wp-gold-dim);
    border: 1px solid rgba(184, 137, 58, 0.25);
    color: var(--wp-gold);
  }

  .wp-card--buiten .wp-card-icon {
    background: var(--wp-buiten-dim);
    border: 1px solid rgba(29, 122, 95, 0.3);
    color: #4ade80;
  }

  /* Content */
  .wp-card-content {
    display: grid;
    gap: 10px;
    flex: 1;
  }

  .wp-card-badge {
    display: inline-flex;
    height: 22px;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
    background: var(--wp-gold-dim);
    border: 1px solid rgba(184, 137, 58, 0.25);
    color: var(--wp-gold);
  }

  .wp-card-badge--buiten {
    background: var(--wp-buiten-dim);
    border-color: rgba(29, 122, 95, 0.3);
    color: #4ade80;
  }

  .wp-card-title {
    margin: 0;
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .wp-card-desc {
    margin: 0;
    color: var(--wp-muted);
    font-size: clamp(0.82rem, 1.4vw, 0.9rem);
    line-height: 1.6;
  }

  .wp-card-tags {
    list-style: none;
    margin: 6px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .wp-card-tags li {
    height: 24px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 0.72rem;
    font-weight: 650;
    color: rgba(247, 242, 234, 0.7);
  }

  /* Arrow */
  .wp-card-arrow {
    position: absolute;
    top: clamp(20px, 3vw, 32px);
    right: clamp(20px, 3vw, 32px);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--wp-muted);
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .wp-card--winkel:hover .wp-card-arrow,
  .wp-card--winkel:focus-visible .wp-card-arrow {
    background: var(--wp-gold-dim);
    border-color: rgba(184, 137, 58, 0.3);
    color: var(--wp-gold);
    transform: translateX(3px);
  }

  .wp-card--buiten:hover .wp-card-arrow,
  .wp-card--buiten:focus-visible .wp-card-arrow {
    background: var(--wp-buiten-dim);
    border-color: rgba(29, 122, 95, 0.3);
    color: #4ade80;
    transform: translateX(3px);
  }

  /* ──────────────────────────────────────────────
     TIP
  ────────────────────────────────────────────── */
  .wp-tip {
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 0;
    color: var(--wp-muted);
    font-size: 0.78rem;
    animation: wp-fade-up 0.55s 0.2s ease both;
  }

  .wp-tip svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* ──────────────────────────────────────────────
     FOOTER
  ────────────────────────────────────────────── */
  .wp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.06);
    animation: wp-fade-up 0.5s 0.25s ease both;
  }

  .wp-footer p {
    margin: 0;
    color: var(--wp-muted);
    font-size: 0.75rem;
    opacity: 0.65;
  }

  .wp-logout {
    color: var(--wp-muted);
    font-size: 0.78rem;
    font-weight: 650;
    text-decoration: none;
    transition: color 0.15s ease;
    opacity: 0.75;
  }

  .wp-logout:hover,
  .wp-logout:focus-visible {
    color: var(--wp-warm);
    opacity: 1;
  }

  .wp-logout:focus-visible {
    outline: 2px solid var(--wp-gold);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* ──────────────────────────────────────────────
     ANIMATIONS
  ────────────────────────────────────────────── */
  @keyframes wp-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes wp-fade-down {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ──────────────────────────────────────────────
     RESPONSIVE — TABLET (≤ 700px)
  ────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .wp-cards {
      grid-template-columns: 1fr;
      max-width: 480px;
    }

    .wp-card {
      padding: 24px;
    }

    .wp-card-icon {
      width: 52px;
      height: 52px;
    }
  }

  /* ──────────────────────────────────────────────
     RESPONSIVE — MOBILE (≤ 480px)
  ────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .wp-shell {
      padding: 16px;
      gap: 24px;
    }

    .wp-logo {
      height: 30px;
    }

    .wp-logo-wrap {
      padding: 8px 12px;
    }

    .wp-welcome-name {
      max-width: 140px;
      font-size: 0.82rem;
    }

    .wp-card {
      padding: 20px;
      border-radius: 16px;
    }

    .wp-card-icon {
      width: 46px;
      height: 46px;
      border-radius: 12px;
    }

    .wp-card-arrow {
      top: 16px;
      right: 16px;
      width: 30px;
      height: 30px;
    }

    .wp-footer {
      flex-direction: column;
      align-items: center;
      gap: 8px;
      text-align: center;
    }
  }

  /* ──────────────────────────────────────────────
     REDUCED MOTION
  ────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .wp-intro,
    .wp-cards,
    .wp-tip,
    .wp-footer,
    .wp-header {
      animation: none;
    }

    .wp-glow {
      animation: none;
    }

    .wp-card {
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .wp-card:hover,
    .wp-card:focus-visible {
      transform: none;
    }
  }
</style>
