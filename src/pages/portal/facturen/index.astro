---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import InvoiceWorkspace from "../../../components/invoices/InvoiceWorkspace";
import { PageHeader } from "../../../components/ui/layout/PageHeader";
import { canViewFinancials } from "../../../lib/auth/session";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

// Facturen zijn in de buitendienst-werkplek server-side geblokkeerd
// (ensureNotFieldMode): stuur field-sessies terug i.p.v. een pagina te tonen
// waarvan elke query gegarandeerd faalt.
if (session.workspaceMode === "field") {
  return Astro.redirect("/portal/buitendienst/vandaag");
}

// Een kijker (viewer) mag geen financiële data zien; de facturen-queries
// weigeren die rol server-side, dus de pagina zou alleen fouten tonen.
if (!canViewFinancials(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Facturen" session={session}>
  <PageHeader
    eyebrow="Financieel"
    title="Facturen"
    description="Overzicht van alle facturen. Registreer betalingen en volg openstaande bedragen op."
  />
  <InvoiceWorkspace client:load session={session} />
</PortalLayout>
