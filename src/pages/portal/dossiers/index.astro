---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import DossierTabs from "../../../components/dossiers/DossierTabs.astro";
import DossierWorkspace from "../../../components/dossiers/DossierWorkspace";
import { PageHeader } from "../../../components/ui/layout/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}
---

<PortalLayout title="Dossiers" session={session}>
  <PageHeader
    eyebrow="Winkel"
    title="Dossiers"
    description="Zoek klanten, projecten en offertes vanuit een plek en werk direct verder in het juiste dossier."
  />
  <DossierTabs active="overview" />

  <DossierWorkspace client:load session={session} />
</PortalLayout>
