---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ProjectDetail from "../../../components/projects/ProjectDetail";
import { Breadcrumbs } from "../../../components/layout/Breadcrumbs";

const session = Astro.locals.session;
const projectId = Astro.params.id ?? "";
const breadcrumbs = [
  { label: "Start", href: "/portal" },
  { label: "Dossiers", href: "/portal/dossiers" },
  { label: "Project" }
];

if (!session) {
  return Astro.redirect("/login");
}
---

<PortalLayout title="Project" session={session}>
  <Breadcrumbs items={breadcrumbs} />
  <ProjectDetail client:load session={session} projectId={projectId} />
</PortalLayout>
