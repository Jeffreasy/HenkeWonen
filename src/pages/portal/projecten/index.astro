---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ProjectWorkspace from "../../../components/projects/ProjectWorkspace";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}
---

<PortalLayout title="Projecten" session={session}>
  <PageHeader
    eyebrow="Dossiers"
    title="Projectdossiers"
    description="Maak en beheer projecten als werkdossiers voor inmeting, offerte, uitvoering en opvolging."
  >
    <a class="button secondary" href="/portal/dossiers">Terug naar dossiers</a>
  </PageHeader>
  <ProjectWorkspace client:load session={session} />
</PortalLayout>
