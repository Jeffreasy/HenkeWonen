---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import CatalogDataIssues from "../../../components/catalog/CatalogDataIssues";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/layout/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Productcontrole" session={session}>
  <PageHeader
    eyebrow="Catalogus"
    title="Productcontrole"
    description="Beoordeel dubbele EAN-signalen en leg vast welke producten bewust gescheiden blijven."
  >
    <a class="ui-button ui-button-secondary" href="/portal/catalogus">Terug naar catalogus</a>
  </PageHeader>
  <CatalogDataIssues client:load session={session} />
</PortalLayout>
