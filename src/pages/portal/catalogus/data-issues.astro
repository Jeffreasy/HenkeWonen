---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import CatalogDataIssues from "../../../components/catalog/CatalogDataIssues";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Productcontrole" session={session}>
  <PageHeader
    eyebrow="Catalogus"
    title="Productcontrole"
    description="Controleer producten die dezelfde EAN gebruiken. Er wordt niets automatisch samengevoegd."
  >
    <a class="button secondary" href="/portal/catalogus">Terug naar catalogus</a>
  </PageHeader>
  <CatalogDataIssues client:load session={session} />
</PortalLayout>
