---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ProductList from "../../../components/catalog/ProductList";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

const showProductControl = canManage(session.role);
---

<PortalLayout title="Catalogus" session={session}>
  <PageHeader
    eyebrow="Producten"
    title="Catalogus"
    description="Zoek producten, leveranciers, kleuren en verkoopprijzen."
  >
    {showProductControl ? (
      <a class="button secondary" href="/portal/catalogus/data-issues">Productcontrole</a>
    ) : null}
  </PageHeader>
  <ProductList client:load session={session} />
</PortalLayout>
