---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import QuoteWorkspace from "../../../components/quotes/QuoteWorkspace";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;
const quoteId = Astro.params.id ?? "";
const breadcrumbs = [
  { label: "Start", href: "/portal" },
  { label: "Offertes", href: "/portal/offertes" },
  { label: "Offerte" }
];

if (!session) {
  return Astro.redirect("/login");
}
---

<PortalLayout title="Offerte" session={session}>
  <PageHeader
    eyebrow="Offerte"
    title="Offerte samenstellen"
    description="Werk de offerte bij, controleer posten en bekijk de klantversie."
    breadcrumbs={breadcrumbs}
  />
  <QuoteWorkspace client:load session={session} quoteId={quoteId} />
</PortalLayout>
