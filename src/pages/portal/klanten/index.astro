---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import DossierTabs from "../../../components/dossiers/DossierTabs.astro";
import CustomerWorkspace from "../../../components/customers/CustomerWorkspace";
import { PageHeader } from "../../../components/ui/layout/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}
---

<PortalLayout title="Klanten" session={session}>
  <PageHeader
    eyebrow="Winkel"
    title="Klanten"
    description="Zoek klanten, open dossiers en leg nieuwe aanvragen vast."
  />
  <DossierTabs active="customers" />
  <CustomerWorkspace client:load session={session} />
</PortalLayout>
