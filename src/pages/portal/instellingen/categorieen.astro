---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import CategoriesSettings from "../../../components/settings/CategoriesSettings";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Productgroepen" session={session}>
  <PageHeader
    eyebrow="Beheer"
    title="Productgroepen"
    description="Bekijk de indeling waarmee producten en werkzaamheden gegroepeerd worden."
  >
    <div class="toolbar">
      <a class="button secondary" href="/portal/instellingen/werkzaamheden">Werkzaamheden</a>
      <a class="button secondary" href="/portal/instellingen/offertetemplates">Offerteteksten</a>
    </div>
  </PageHeader>
  <CategoriesSettings client:load session={session} />
</PortalLayout>
