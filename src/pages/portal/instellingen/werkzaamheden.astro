---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ServiceRulesSettings from "../../../components/settings/ServiceRulesSettings";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Werkzaamheden" session={session}>
  <PageHeader
    eyebrow="Beheer"
    title="Werkzaamheden en prijzen"
    description="Beheer vaste werkzaamheden, toeslagen en standaardprijzen voor offertes."
  >
    <div class="toolbar">
      <a class="button secondary" href="/portal/instellingen/categorieen">Productgroepen</a>
      <a class="button secondary" href="/portal/instellingen/offertetemplates">Offerteteksten</a>
    </div>
  </PageHeader>
  <ServiceRulesSettings client:load session={session} />
</PortalLayout>
