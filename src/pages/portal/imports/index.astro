---
import PortalLayout from "../../../components/layout/PortalLayout.astro";
import ImportPreview from "../../../components/imports/ImportPreview";
import ProductionReadiness from "../../../components/imports/ProductionReadiness";
import { canManage } from "../../../lib/auth/session";
import { PageHeader } from "../../../components/ui/layout/PageHeader";

const session = Astro.locals.session;

if (!session) {
  return Astro.redirect("/login");
}

if (!canManage(session.role)) {
  return Astro.redirect("/portal");
}
---

<PortalLayout title="Prijslijsten" session={session}>
  <PageHeader
    eyebrow="Beheer"
    title="Prijslijsten controleren"
    description="Bekijk aangeleverde leverancierbestanden en de controle-meldingen. Het verwerken naar de catalogus gebeurt buiten de portal (via de importscripts van de beheerder)."
  />
  <ProductionReadiness client:load session={session} />
  <ImportPreview client:load session={session} />
</PortalLayout>
