---
import { ClientRouter } from "astro:transitions";
import "../../styles/global.css";
import ThemeScript from "./ThemeScript.astro";
import FieldNavigation from "./FieldNavigation";
import { ShellLoadingController } from "./ShellLoadingController";
import { FieldFab } from "../field/FieldFab";
import type { AppSession } from "../../lib/auth/session";

type Props = {
  title: string;
  session: AppSession;
};

const { title, session } = Astro.props;
const pathname = Astro.url.pathname;
const theme = Astro.cookies.get("theme")?.value || "light";
---

<html lang="nl" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Henke Wonen Buitendienst</title>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <ThemeScript />
  </head>
  <body>
    <a href="#hoofdinhoud" class="skip-link">Naar inhoud</a>
    <div class="portal-frame field-frame">
      <FieldNavigation client:load session={session} pathname={pathname} />
      <main class="field-main" id="hoofdinhoud" tabindex="-1">
        <div class="field-content">
          <slot />
        </div>
      </main>
      <ShellLoadingController client:load />
      <!-- Field FAB — contextgevoelig: lijstscherm vs. projectscherm -->
      <FieldFab client:load session={session} pathname={pathname} />
    </div>
  </body>
</html>
