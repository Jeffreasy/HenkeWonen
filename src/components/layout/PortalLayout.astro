---
import "../../styles/global.css";
import Sidebar from "./Sidebar";
import PortalTopbar from "./PortalTopbar";
import { ShellLoadingController } from "./ShellLoadingController";
import { ToastContainer } from "../ui/overlays/ToastContainer";
import { KeyboardShortcutController } from "./KeyboardShortcutController";
import type { AppSession } from "../../lib/auth/session";

type Props = {
  title: string;
  session: AppSession;
};

const { title, session } = Astro.props;
const pathname = Astro.url.pathname;
const theme = Astro.cookies.get("theme")?.value || "light";
---

<html lang="nl" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | Henke Wonen</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const storedTheme = localStorage.getItem("theme");
        if (storedTheme) {
          document.documentElement.setAttribute("data-theme", storedTheme);
          return;
        }
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", systemTheme);
      })();
    </script>
  </head>
  <body>
    <div class="portal-frame">
      <Sidebar client:load session={session} pathname={pathname} />
      <PortalTopbar client:load session={session} pathname={pathname} />
      <main class="portal-main">
        <div class="portal-content">
          <slot />
        </div>
      </main>
      <ShellLoadingController client:load />
    </div>
    <!-- Toast container — always present, renders above all overlays (z-index 1500) -->
    <ToastContainer client:load />
    <!-- Keyboard shortcut controller — registers global shortcuts + help modal -->
    <KeyboardShortcutController client:load />
  </body>
</html>
